DATABASE_URL=postgresql+asyncpg://canvex:canvex@localhost:5432/canvex
REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=change-me-in-development
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=15
# REFRESH_TOKEN_EXPIRE_DAYS=7
GEMINI_API_KEY=
# GEMINI_VISION_MODEL=gemini-1.5-pro
# GEMINI_EMBEDDING_MODEL=models/text-embedding-004
API_BASE_URL=http://localhost:8000
ENVIRONMENT=development
# Comma-separated allowed frontend origins (dev defaults cover localhost).
# In production set this to your Vercel domain(s), e.g.
# CORS_ALLOW_ORIGINS=https://canvex.vercel.app
# CORS_ALLOW_ORIGINS=
# Auto-run DB migrations on boot. Unset → on in production only (plan 13.7).
# RUN_MIGRATIONS_ON_STARTUP=false
# ── Social / institutional sign-in ──────────────────────────────────────────
# Google OAuth 2.0 "Web application" client ID (Google Cloud Console). Blank →
# the "Sign in with Google" button stays hidden. The client ID is public and is
# served to the frontend via GET /auth/config, so set it here only.
# GOOGLE_CLIENT_ID=1234567890-abc123.apps.googleusercontent.com
# Extra institutional domains for "Institutional Login", beyond the built-in
# .edu / .ac acceptance (comma-separated). Any .edu / .ac email always works;
# set this only to also allow a non-academic institutional domain.
# INSTITUTIONAL_EMAIL_DOMAINS=campus.example.org
